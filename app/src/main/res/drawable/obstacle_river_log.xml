<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="96dp"
    android:height="48dp"
    android:viewportWidth="96"
    android:viewportHeight="48">
    <!--
        Vector art lesson:
        width/height are the size Android lays out in dp.
        viewportWidth/viewportHeight are the coordinate grid we draw on.
        Each path is one colored shape. Later paths draw on top of earlier ones.
        The group rotation gives the log a tiny tilt; set it closer to 0 to make
        the log look straighter.
    -->

    <group
        android:pivotX="48"
        android:pivotY="24"
        android:rotation="1.5">

        <!-- shadow -->
        <path
            android:fillColor="#4A2A18"
            android:pathData="M18,34 L78,34 Q88,34 90,28 L90,36 Q88,42 78,42 L18,42 Q8,42 6,36 L6,28 Q8,34 18,34 Z" />

        <!-- main bark -->
        <path
            android:fillColor="#8B4A22"
            android:pathData="M18,10 L78,10 Q90,10 92,24 Q90,38 78,38 L18,38 Q6,38 4,24 Q6,10 18,10 Z" />

        <!-- dark bottom bark -->
        <path
            android:fillColor="#5A2D17"
            android:pathData="M18,29 L78,29 Q88,29 91,24 Q90,38 78,38 L18,38 Q7,38 4,24 Q8,29 18,29 Z" />

        <!-- cut end -->
        <path
            android:fillColor="#D89435"
            android:pathData="M18,10 Q6,10 4,24 Q6,38 18,38 Q30,38 32,24 Q30,10 18,10 Z" />

        <!-- inner cut -->
        <path
            android:fillColor="#F2B64A"
            android:pathData="M18,14 Q10,14 8,24 Q10,34 18,34 Q26,34 28,24 Q26,14 18,14 Z" />

        <!-- rings -->
        <path
            android:strokeColor="#9F621F"
            android:strokeWidth="2"
            android:fillColor="@android:color/transparent"
            android:pathData="M18,18 Q13,18 12,24 Q13,30 18,30 Q23,30 24,24 Q23,18 18,18 Z" />

        <path
            android:strokeColor="#8A541B"
            android:strokeWidth="2"
            android:fillColor="@android:color/transparent"
            android:pathData="M18,22 Q16,22 16,24 Q16,26 18,26 Q20,26 20,24 Q20,22 18,22 Z" />

        <!-- bark lines -->
        <path
            android:strokeColor="#3A1C0D"
            android:strokeWidth="2"
            android:fillColor="@android:color/transparent"
            android:pathData="M35,15 L58,15" />
        <path
            android:strokeColor="#5A2D17"
            android:strokeWidth="2"
            android:fillColor="@android:color/transparent"
            android:pathData="M42,21 L75,21" />
        <path
            android:strokeColor="#3A1C0D"
            android:strokeWidth="2"
            android:fillColor="@android:color/transparent"
            android:pathData="M34,28 L64,28" />
        <path
            android:strokeColor="#B76825"
            android:strokeWidth="2"
            android:fillColor="@android:color/transparent"
            android:pathData="M48,18 L69,18" />
        <path
            android:strokeColor="#2A1208"
            android:strokeWidth="2"
            android:fillColor="@android:color/transparent"
            android:pathData="M55,34 L80,34" />

        <!-- branch nub -->
        <path
            android:fillColor="#7A3D1C"
            android:pathData="M61,10 L67,4 L73,6 L70,17 L62,17 Z" />

        <path
            android:fillColor="#F0A83B"
            android:pathData="M67,4 L73,6 L71,9 L65,8 Z" />

        <path
            android:strokeColor="#2A1208"
            android:strokeWidth="2"
            android:fillColor="@android:color/transparent"
            android:pathData="M61,10 L67,4 L73,6 L70,17 L62,17 Z" />
    </group>
</vector>
